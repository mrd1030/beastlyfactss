{
  "expo": {
    "name": "beastlyfactsapp",
    "slug": "beastlyfactsapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "backgroundColor": "#F4F7F2",
    "icon": "./assets/images/icon.png",
    "scheme": "beastlyfactsapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-system-ui",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-sqlite",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "BeastlyFacts uses your photo library so you can add a picture of your pet."
        }
      ],
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "CareStatusWidget",
              "displayName": "Pet Care Status",
              "description": "Shows due care tasks and health watch updates at a glance.",
              "supportedFamilies": ["systemSmall", "systemMedium"]
            }
          ]
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "PetCareQuickWidget",
              "label": "Pet Quick Checks",
              "description": "Shows due care counts and the latest pet activity.",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical"
            },
            {
              "name": "DailyFactQuickWidget",
              "label": "Daily Fact",
              "description": "Shows today’s animal fact and opens the fact feed.",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
